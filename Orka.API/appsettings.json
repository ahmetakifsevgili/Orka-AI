{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=OrkaDB;Trusted_Connection=True;TrustServerCertificate=True;",
    "Redis": "127.0.0.1:6379,abortConnect=false"
  },
  "Database": {
    "AutoMigrateOnStartup": false,
    "RequireAppliedMigrationsForReadiness": false
  },
  "Cors": {
    "AllowAnyOriginInDevelopment": false,
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://127.0.0.1:3000"
    ]
  },
  "ContentSafety": {
    "Uploads": {
      "MaxFileBytes": 10485760,
      "MaxMultipartBodyBytes": 11534336,
      "MaxPdfPages": 100,
      "MaxExtractedChars": 200000,
      "MaxChunksPerSource": 100,
      "MaxEmbeddingChunksPerUpload": 100,
      "MaxEmbeddingChunksPerUserPerDay": 500,
      "MaxUploadsPerUserPerHour": 10,
      "MaxKorteksFileResearchPerUserPerHour": 10,
      "MaxSourcesPerTopic": 50
    }
  },
  "SecurityHeaders": {
    "Csp": {
      "ReportOnly": false,
      "AdditionalConnectSrc": []
    }
  },
  "JWT": {
    "Secret": "",
    "Issuer": "orka-api",
    "Audience": "orka-client",
    "AccessTokenExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 30
  },
  "Auth": {
    "RefreshCookie": {
      "Name": "orka_refresh",
      "Path": "/api/auth",
      "SameSite": "Strict"
    }
  },
  "AI": {
    "Primary": "GitHubModels",
    "Reliability": {
      "MaxAttemptsPerRequest": 2,
      "ProviderCooldownSeconds": 60,
      "StrictExternalFallbackProviders": [ "GitHubModels" ],
      "FallbackEnabled": true,
      "FailFastStatusCodes": [ 401, 403 ]
    },
    "Cost": {
      "Enabled": true,
      "GlobalDailyUsdLimit": null,
      "UserDailyUsdLimit": null,
      "GlobalDailyTokenLimit": null,
      "UserDailyTokenLimit": null,
      "RoleBudgets": {
        "Tutor": { "MaxOutputTokens": 2048 },
        "DeepPlan": { "MaxOutputTokens": 16384 },
        "Quiz": { "MaxOutputTokens": 32768 },
        "Summarizer": { "MaxOutputTokens": 1024 },
        "Analyzer": { "MaxOutputTokens": 1024 },
        "Korteks": { "MaxOutputTokens": 4096 }
      }
    },
    "GitHubModels": {
      "Token": "",
      "BaseUrl": "https://models.github.ai/inference",
      "MaxOutputTokens": 32768,
      "Agents": {
        "Tutor": {
          "Model": "gpt-4o"
        },
        "DeepPlan": {
          "Model": "openai/gpt-4o"
        },
        "Analyzer": {
          "Model": "gpt-4o-mini"
        },
        "Summarizer": {
          "Model": "gpt-4o-mini"
        },
        "Korteks": {
          "Model": "Meta-Llama-3.1-405B-Instruct"
        },
        "Supervisor": {
          "Model": "gpt-4o-mini"
        },
        "Grader": {
          "Model": "gpt-4o-mini"
        },
        "Evaluator": {
          "Model": "gpt-4o-mini"
        },
        "TieredPlanner": {
          "Model": "gpt-4o"
        },
        "Quiz": {
          "Model": "openai/gpt-4o"
        },
        "Diagnostic": {
          "Model": "openai/gpt-4o"
        },
        "Remedial": {
          "Model": "gpt-4o-mini"
        },
        "Visual": {
          "Model": "gpt-4o-mini"
        },
        "Classroom": {
          "Model": "gpt-4o-mini"
        }
      }
    },
    "AgentRouting": {
      "Tutor":            { "Provider": "GitHubModels", "Model": "gpt-4o" },
      "DeepPlan":         { "Provider": "GitHubModels", "Model": "openai/gpt-4o" },
      "Analyzer":         { "Provider": "GitHubModels", "Model": "gpt-4o-mini" },
      "Supervisor":       { "Provider": "GitHubModels", "Model": "gpt-4o-mini" },
      "Grader":           { "Provider": "GitHubModels", "Model": "gpt-4o-mini" },
      "Evaluator":        { "Provider": "GitHubModels", "Model": "gpt-4o-mini" },
      "_EvaluatorAlternative": "DeepSeek-V3.1 ikinci-görüş için: { Provider: SambaNova, Model: DeepSeek-V3 } olarak değiştir.",
      "Summarizer":       { "Provider": "GitHubModels", "Model": "gpt-4o-mini" },
      "Korteks":          { "Provider": "OpenRouter",   "Model": "anthropic/claude-opus-4-7" },
      "IntentClassifier": { "Provider": "GitHubModels", "Model": "gpt-4o-mini" },
      "TieredPlanner":    { "Provider": "GitHubModels", "Model": "gpt-4o" },
      "Quiz":             { "Provider": "GitHubModels", "Model": "openai/gpt-4o" },
      "Diagnostic":       { "Provider": "GitHubModels", "Model": "openai/gpt-4o" },
      "Remedial":         { "Provider": "GitHubModels", "Model": "gpt-4o-mini" },
      "Visual":           { "Provider": "GitHubModels", "Model": "gpt-4o-mini" },
      "Classroom":        { "Provider": "GitHubModels", "Model": "gpt-4o-mini" }
    },
    "Groq": {
      "ApiKey": "",
      "Model": "llama-3.3-70b-versatile",
      "BaseUrl": "https://api.groq.com/openai/v1"
    },
    "SambaNova": {
      "ApiKey": "",
      "Model": "Llama-4-Maverick-17B-128E-Instruct",
      "BaseUrl": "https://api.sambanova.ai/v1/chat/completions"
    },
    "Cerebras": {
      "ApiKey": "",
      "Model": "llama3.1-8b",
      "BaseUrl": "https://api.cerebras.ai/v1/chat/completions"
    },
    "OpenRouter": {
      "ApiKey": "",
      "Model": "anthropic/claude-3-5-haiku",
      "FallbackModel": "openai/gpt-4o-mini",
      "BaseUrl": "https://openrouter.ai/api/v1",
      "Agents": {
        "DeepPlan": {
          "Model": "openai/gpt-oss-120b",
          "ApiKey": ""
        },
        "Tutor": {
          "Model": "meta-llama/llama-3.3-70b-instruct",
          "ApiKey": ""
        },
        "Wiki": {
          "Model": "qwen/qwen3-next-80b-a3b-instruct",
          "ApiKey": ""
        },
        "Analyzer": {
          "Model": "nvidia/nemotron-nano-9b-v2",
          "ApiKey": ""
        },
        "Summarizer": {
          "Model": "openai/gpt-oss-20b",
          "ApiKey": ""
        },
        "Korteks": {
          "Model": "meta-llama/llama-3.3-70b-instruct",
          "ApiKey": ""
        },
        "Fallback": {
          "ApiKey": ""
        }
      }
    },
    "Gemini": {
      "ApiKey": "",
      "UseVertexAi": true,
      "ModelDeepPlan": "gemini-3.1-pro-preview",
      "ModelTutor": "gemini-3.1-pro-preview",
      "ModelQuiz": "gemini-3.1-pro-preview",
      "MaxQuizOutputTokens": 32768,
      "ToolAdvisory": {
        "Enabled": false,
        "Model": "gemini-3.1-pro-preview"
      },
      "BaseUrl": "https://aiplatform.googleapis.com/v1/projects/orka-494803/locations/global/publishers/google/models"
    },
    "Tavily": {
      "Enabled": false,
      "ApiKey": "",
      "BaseUrl": "https://api.tavily.com"
    },
    "Albert": {
      "Model": "llama-3.3-70b-versatile",
      "MaxSearchResults": 5,
      "MaxOutputTokens": 4096
    },
    "Cohere": {
      "ApiKey": "",
      "Model": "command-a-03-2025",
      "BaseUrl": "https://api.cohere.com/compatibility/v1",
      "EmbedModel": "embed-multilingual-v3.0"
    },
    "HuggingFace": {
      "ApiKey": "",
      "Model": "meta-llama/Llama-3.1-8B-Instruct",
      "BaseUrl": "https://router.huggingface.co/v1"
    },
    "Mistral": {
      "ApiKey": "",
      "Model": "mistral-small-latest",
      "BaseUrl": "https://api.mistral.ai/v1"
    },
    "YouTube": {
      "ApiKey": ""
    }
  },
  "Limits": {
    "DemoMode": true,
    "FreeUserDailyMessages": 50,
    "ProUserDailyMessages": 500,
    "FreeStorageMB": 3072,
    "ProStorageMB": 15360,
    "MaxContextMessages": 10,
    "MaxContextTokens": 2000
  },
  "RateLimits": {
    "Auth": {
      "Backend": "Auto",
      "AllowInMemoryFallback": false,
      "Login": {
        "PermitLimit": 5,
        "WindowMinutes": 5
      },
      "Register": {
        "PermitLimit": 3,
        "WindowMinutes": 15
      },
      "Refresh": {
        "PermitLimit": 20,
        "WindowMinutes": 5
      }
    }
  },
  "Retention": {
    "AudioBytesDays": 7,
    "TelemetryDays": 30,
    "ToolTraceDays": 30,
    "CleanupWorkerEnabled": false
  },
  "Redis": {
    "Streams": {
      "TutorEventsMaxLength": 1000,
      "TutorEventsTtlHours": 48,
      "MaintenanceWorkerEnabled": false
    }
  },
  "OpenTelemetry": {
    "OtlpEndpoint": ""
  }
}
