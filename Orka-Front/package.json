{
  "name": "orka-front",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "smoke:ui": "node scripts/smoke-ui.mjs",
    "smoke:navigation": "node scripts/smoke-navigation.mjs",
    "smoke:contracts": "node scripts/smoke-endpoints.mjs",
    "smoke:security": "node scripts/smoke-security.mjs",
    "smoke:browser:journey": "playwright test e2e/smoke.spec.ts e2e/onboarding-and-tutor.spec.ts e2e/learning-os-shell.spec.ts",
    "smoke:browser:projection": "playwright test e2e/learning-os-shell.spec.ts --grep @projection",
    "smoke:browser:contracts": "playwright test e2e/notebook-studio-contract.spec.ts",
    "smoke:browser": "npm run smoke:browser:journey && npm run smoke:browser:projection && npm run smoke:browser:contracts",
    "life:browser": "playwright test e2e/life-proof.spec.ts",
    "typecheck": "tsc --noEmit",
    "smoke:build": "vite build",
    "quick:build": "vite build",
    "quick:frontend": "npm run smoke:ui && npm run smoke:contracts && npm run smoke:build",
    "quick:smoke": "npm run smoke:ui && npm run smoke:navigation && npm run smoke:contracts && npm run smoke:security && npm run smoke:browser",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "axios": "^1.9.0",
    "driver.js": "^1.4.0",
    "force-graph": "^1.51.4",
    "framer-motion": "^12.0.0",
    "katex": "^0.16.45",
    "lucide-react": "^0.511.0",
    "mermaid": "^11.14.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-force-graph-2d": "^1.29.1",
    "react-hot-toast": "^2.5.2",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.10.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "wouter": "^3.7.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.1.4",
    "@types/node": "^25.5.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "tailwindcss": "^4.1.4",
    "tw-animate-css": "^1.3.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.2",
    "vitest": "^4.1.8"
  }
}
